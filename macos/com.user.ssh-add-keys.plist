<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.ssh-add-keys</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>for pub in "$HOME"/.ssh/*.pub; do key="${pub%.pub}"; [ -f "$key" ] &amp;&amp; /usr/bin/ssh-add "$key"; done</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
